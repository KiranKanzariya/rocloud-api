{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=rocloud_dev;Username=rocloud_dev_user;Password=NjQc98y90AGe;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "Logs": {
    "RetentionDays": 30
  },
  "AllowedHosts": "*",
  "App": {
    "WebUrl": "http://localhost:4200",
    "ApiUrl": "http://localhost:5000",
    "TenantUrlFormat": "https://{subdomain}.localhost:4200"
  },
  "Cache": {
    "Provider": "InMemory",
    "SizeLimit": 10000,
    "CompactionPercentage": 0.2,
    "DefaultExpiryMinutes": 30
  },
  "Storage": {
    "Provider": "Local",
    "LocalPath": "App_Data/files",
    "SignedUrlExpiryMinutes": 15
  },
  "Files": {
    "DeliveryProofMaxBytes": 5242880
  },
  "Localization": {
    "DefaultCulture": "en",
    "SupportedCultures": ["en", "hi", "gu", "mr", "ta", "te", "kn", "pa", "bn"]
  },
  "Billing": {
    "GstRate": "0.18",
    "DefaultDueInDays": 15,
    "InvoiceLinkExpiryDays": 7
  },
  "Tenant": {
    "TrialDays": 14
  },
  "Security": {
    "BcryptWorkFactor": 12,
    "MaxLoginAttempts": 5,
    "LockoutMinutes": 15,
    "PasswordResetTokenTtlMinutes": 60
  },
  "Audit": {
    "MaxRequestBodyBytes": 102400
  },
  "Subscription": {
    "OverdueGraceDays": 7,
    "TrialGraceDays": 2
  },
  "Jobs": {
    "SubscriptionExpiryWarnDays": 7,
    "SubscriptionSuspendGraceDays": 30,
    "AmcReminderLeadDays": 7,
    "_comment_ReminderThrottle": "A customer/visit/order/tenant reminded within *MinIntervalDays is skipped on later runs (recorded in reminder_log), so reminders don't re-send every time the job runs. Default: payment 3, amc 7, advance-order 7, subscription-expiry 3.",
    "PaymentReminderMinIntervalDays": 3,
    "AmcReminderMinIntervalDays": 7,
    "AdvanceOrderReminderMinIntervalDays": 7,
    "SubscriptionExpiryReminderMinIntervalDays": 3,
    "SubscriptionInvoiceLeadDays": 5
  },
  "SecurityHeaders": {
    "HstsMaxAgeSeconds": 31536000
  },
  "Jwt": {
    "_comment": "Jwt:Secret comes from User Secrets in development (dotnet user-secrets). Issuer/Audience/expiry below.",
    "Issuer": "rocloud.app",
    "Audience": "rocloud.app",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 30,
    "Secret": ""
  },
  "Cors": {
    "_comment": "https origins keep the portals schemeful same-site with the HTTPS API. The *.localhost entries let the owner portal be accessed per-tenant (e.g. https://sharma-ro.localhost:4200), matched via SetIsOriginAllowedToAllowWildcardSubdomains.",
    "Origins": [
      "http://localhost:4200", "http://localhost:4201",
      "https://localhost:4200", "https://localhost:4201",
      "https://*.localhost:4200", "https://*.localhost:4201"
    ]
  },
  "IpRateLimiting": {
    "_comment": "Relaxed limits for local development (register/login are easy to hit while testing).",
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "GeneralRules": [
      { "Endpoint": "*", "Period": "1m", "Limit": 600 },
      { "Endpoint": "POST:/api/auth/login", "Period": "15m", "Limit": 100 },
      { "Endpoint": "POST:/api/auth/google", "Period": "15m", "Limit": 100 },
      { "Endpoint": "POST:/api/auth/register", "Period": "1h", "Limit": 100 },
      { "Endpoint": "POST:/api/auth/forgot-password", "Period": "1h", "Limit": 50 },
      { "Endpoint": "POST:/api/auth/reset-password", "Period": "1h", "Limit": 50 },
      { "Endpoint": "POST:/api/auth/find-workspace", "Period": "1h", "Limit": 50 },
      { "Endpoint": "POST:/api/platform/auth/login", "Period": "15m", "Limit": 100 },
      { "Endpoint": "POST:/api/platform/auth/forgot-password", "Period": "1h", "Limit": 50 },
      { "Endpoint": "POST:/api/platform/auth/reset-password", "Period": "1h", "Limit": 50 }
    ]
  },
  "Google": {
    "_comment": "Supply ClientId / ClientSecret via User Secrets in development.",
    "ClientId": "",
    "ClientSecret": ""
  },
  "Razorpay": {
    "BaseUrl": "https://api.razorpay.com/v1/",
    "Currency": "INR",
    "SubscriptionTotalCount": 12,
    "KeyId": "",
    "KeySecret": "",
    "WebhookSecret": ""
  },
  "Email": {
    "_comment": "Active transactional email provider: SendGrid | Resend. Both degrade to logging when their key is blank.",
    "Provider": "Resend"
  },
  "SendGrid": {
    "ApiKey": "",
    "FromEmail": "no-reply@rocloud.app",
    "FromName": "ROCloud"
  },
  "Resend": {
    "ApiKey": "",
    "FromEmail": "no-reply@mail.rocloud.in",
    "FromName": "ROCloud"
  },
  "MSG91": {
    "AuthKey": "",
    "SenderId": "ROCLOU",
    "WhatsAppNumber": "",
    "ShortUrl": "0",
    "SmsUrl": "https://control.msg91.com/api/v5/flow/",
    "WhatsAppUrl": "https://control.msg91.com/api/v5/whatsapp/whatsapp-outbound-message/"
  },
  "Notifications": {
    "_comment": "Master on/off switch per outbound channel. When false, that channel never sends (regardless of API keys or plan). WhatsApp also requires the tenant's plan feature. Missing key defaults to true.",
    "EmailEnabled": true,
    "SmsEnabled": false,
    "WhatsAppEnabled": false,
    "CustomerNotifications": {
      "_comment": "Per-event switches for the tenant → customer notifications, layered on top of the channel switches above (an event sends only when its switch AND the channel are on). All off for v1. Missing key defaults to true. InvoiceSent gates only the customer email — the PDF is still generated, stored and the invoice marked Sent. The three reminders are recurring jobs that exit immediately when their switch is off.",
      "InvoiceSent": false,
      "PaymentReminder": false,
      "AmcReminder": false,
      "AdvanceOrderReminder": false
    }
  }
}
